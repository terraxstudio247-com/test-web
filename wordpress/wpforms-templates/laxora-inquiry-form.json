{
  "id": "laxora-inquiry-form",
  "field_id": 7,
  "fields": {
    "1": { "id": 1, "type": "text",     "label": "Full Name",                       "required": "1", "size": "large", "placeholder": "Mr. John Carter" },
    "2": { "id": 2, "type": "email",    "label": "Executive Email",                 "required": "1", "size": "large", "placeholder": "name@company.com" },
    "3": { "id": 3, "type": "text",     "label": "Pickup Location",                 "required": "1", "size": "large", "placeholder": "Hotel, airport, or address" },
    "4": { "id": 4, "type": "text",     "label": "Destination / Routing",           "required": "1", "size": "large", "placeholder": "Final destination or stops" },
    "5": { "id": 5, "type": "date-time","label": "Service Date",                     "required": "1", "size": "large", "format": "date" },
    "6": { "id": 6, "type": "textarea", "label": "Bespoke Itinerary Requirements",   "required": "0", "size": "large", "placeholder": "Multi-stop routing, vehicle preference, special requests…" }
  },
  "settings": {
    "form_title": "Laxora — Inquiry",
    "form_desc": "Request a bespoke quotation. Discretion guaranteed.",
    "submit_text": "Request Quote",
    "submit_text_processing": "Sending…",
    "notification_enable": "1",
    "notifications": {
      "1": {
        "notification_name": "Default Notification",
        "email": "{admin_email}",
        "subject": "New Laxora Inquiry from {field_id=\"1\"}",
        "sender_name": "{site_name}",
        "sender_address": "{admin_email}",
        "replyto": "{field_id=\"2\"}",
        "message": "{all_fields}"
      }
    },
    "confirmations": {
      "1": {
        "type": "message",
        "message": "<h3>Inquiry Received</h3><p>Thank you. A senior concierge will reach out personally within one business hour.</p>",
        "message_scroll": "1"
      }
    },
    "honeypot": "1",
    "antispam": "1"
  },
  "meta": {
    "template": "laxora-inquiry"
  }
}
