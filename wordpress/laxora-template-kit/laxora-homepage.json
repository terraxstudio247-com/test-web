{
  "version": "0.4",
  "title": "Laxora — Homepage",
  "type": "page",
  "page_settings": {
    "background_background": "classic",
    "background_color": "#0B0C10",
    "hide_title": "yes"
  },
  "content": [
    {
      "id": "sec-hero",
      "elType": "section",
      "settings": {
        "stretch_section": "section-stretched",
        "layout": "full_width",
        "height": "min-height",
        "custom_height": { "unit": "vh", "size": 100 },
        "content_position": "middle",
        "background_background": "classic",
        "background_image": { "url": "REPLACE_WITH_HERO_URL", "id": "" },
        "background_size": "cover",
        "background_position": "center center",
        "background_overlay_background": "gradient",
        "background_overlay_color": "#0B0C10",
        "background_overlay_color_b": "#0B0C10",
        "background_overlay_color_stop": { "unit": "%", "size": 0 },
        "background_overlay_color_b_stop": { "unit": "%", "size": 100 },
        "background_overlay_opacity": { "size": 0.8 },
        "padding": { "unit": "px", "top": "120", "right": "24", "bottom": "80", "left": "24", "isLinked": false }
      },
      "elements": [
        {
          "id": "col-hero",
          "elType": "column",
          "settings": { "_column_size": 100, "content_position": "center" },
          "elements": [
            {
              "id": "hero-eyebrow",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "— Executive Chauffeur Service —",
                "align": "center",
                "size": "small",
                "header_size": "h6",
                "title_color": "#C5A059",
                "typography_typography": "custom",
                "typography_font_family": "Inter",
                "typography_font_size": { "unit": "px", "size": 11 },
                "typography_font_weight": "500",
                "typography_letter_spacing": { "unit": "px", "size": 6 },
                "typography_text_transform": "uppercase"
              }
            },
            {
              "id": "hero-title",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Precision, Privacy,<br>and <em>Uncompromised</em> Luxury.",
                "align": "center",
                "header_size": "h1",
                "title_color": "#E5E5E5",
                "typography_typography": "custom",
                "typography_font_family": "Cormorant Garamond",
                "typography_font_size": { "unit": "px", "size": 64 },
                "typography_font_weight": "400",
                "typography_line_height": { "unit": "em", "size": 1.05 }
              }
            },
            {
              "id": "hero-lead",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style=\"max-width:640px;margin:24px auto 0;font-weight:300;\">Laxora delivers a discreet, world-class chauffeur experience for executives, dignitaries, and private clientele across the world’s most demanding cities.</p>",
                "align": "center",
                "text_color": "rgba(229,229,229,0.7)"
              }
            },
            {
              "id": "hero-cta-row",
              "elType": "section",
              "isInner": true,
              "settings": { "structure": "20", "gap": "default", "content_position": "middle" },
              "elements": [
                {
                  "id": "col-cta-1",
                  "elType": "column",
                  "settings": { "_column_size": 50, "_inline_size": null, "content_position": "center" },
                  "elements": [
                    {
                      "id": "cta-primary",
                      "elType": "widget",
                      "widgetType": "button",
                      "settings": {
                        "text": "Request Quote",
                        "link": { "url": "#contact" },
                        "align": "right",
                        "background_color": "#C5A059",
                        "button_text_color": "#0B0C10",
                        "hover_background_color": "#E9C77B",
                        "hover_color": "#0B0C10",
                        "border_radius": { "unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": true },
                        "text_padding": { "unit": "px", "top": "16", "right": "40", "bottom": "16", "left": "40", "isLinked": false }
                      }
                    }
                  ]
                },
                {
                  "id": "col-cta-2",
                  "elType": "column",
                  "settings": { "_column_size": 50, "_inline_size": null, "content_position": "center" },
                  "elements": [
                    {
                      "id": "cta-ghost",
                      "elType": "widget",
                      "widgetType": "button",
                      "settings": {
                        "text": "Explore Fleet",
                        "link": { "url": "#fleet" },
                        "align": "left",
                        "background_color": "rgba(0,0,0,0)",
                        "button_text_color": "#E5E5E5",
                        "border_border": "solid",
                        "border_width": { "unit": "px", "top": "1", "right": "1", "bottom": "1", "left": "1", "isLinked": true },
                        "border_color": "rgba(229,229,229,0.3)",
                        "hover_color": "#C5A059",
                        "button_hover_border_color": "#C5A059",
                        "border_radius": { "unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": true },
                        "text_padding": { "unit": "px", "top": "16", "right": "40", "bottom": "16", "left": "40", "isLinked": false }
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "sec-fleet-intro",
      "elType": "section",
      "settings": {
        "background_background": "classic",
        "background_color": "#0B0C10",
        "padding": { "unit": "px", "top": "96", "right": "24", "bottom": "96", "left": "24", "isLinked": false },
        "content_position": "middle"
      },
      "elements": [
        {
          "id": "col-fleet-intro",
          "elType": "column",
          "settings": { "_column_size": 100, "content_position": "center" },
          "elements": [
            {
              "id": "fleet-eyebrow",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "The Laxora Fleet",
                "align": "center",
                "header_size": "h6",
                "title_color": "#C9A6FF",
                "typography_typography": "custom",
                "typography_font_family": "Inter",
                "typography_font_size": { "unit": "px", "size": 11 },
                "typography_font_weight": "600",
                "typography_letter_spacing": { "unit": "px", "size": 4 },
                "typography_text_transform": "uppercase"
              }
            },
            {
              "id": "fleet-title",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Check our Luxury Collection",
                "align": "center",
                "header_size": "h2",
                "title_color": "#E5E5E5",
                "typography_typography": "custom",
                "typography_font_family": "Cormorant Garamond",
                "typography_font_size": { "unit": "px", "size": 48 },
                "typography_font_weight": "400"
              }
            },
            {
              "id": "fleet-lead",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style=\"max-width:720px;margin:20px auto 0;text-align:center;font-weight:300;\">Laxora curates a premier portfolio of executive vehicles — from chauffeur-driven sedans and ultra-luxury SUVs to MPVs and coaches — delivering an uncompromised standard of comfort, privacy, and punctuality across every journey.</p>",
                "text_color": "rgba(229,229,229,0.6)"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "sec-pillars",
      "elType": "section",
      "settings": {
        "background_background": "classic",
        "background_color": "#0B0C10",
        "padding": { "unit": "px", "top": "96", "right": "24", "bottom": "96", "left": "24", "isLinked": false },
        "structure": "30"
      },
      "elements": [
        {
          "id": "col-pillar-1",
          "elType": "column",
          "settings": { "_column_size": 33, "content_position": "top" },
          "elements": [
            { "id": "p1-title", "elType": "widget", "widgetType": "heading", "settings": { "title": "Absolute Punctuality", "header_size": "h3", "title_color": "#E5E5E5", "typography_typography": "custom", "typography_font_family": "Cormorant Garamond", "typography_font_size": { "unit": "px", "size": 28 } } },
            { "id": "p1-desc",  "elType": "widget", "widgetType": "text-editor", "settings": { "editor": "<p>Real-time tracking protocols and meticulously orchestrated logistics ensure your chauffeur arrives precisely when expected — every time.</p>", "text_color": "rgba(229,229,229,0.6)" } }
          ]
        },
        {
          "id": "col-pillar-2",
          "elType": "column",
          "settings": { "_column_size": 33, "content_position": "top" },
          "elements": [
            { "id": "p2-title", "elType": "widget", "widgetType": "heading", "settings": { "title": "Elite Chauffeur Protocol", "header_size": "h3", "title_color": "#E5E5E5", "typography_typography": "custom", "typography_font_family": "Cormorant Garamond", "typography_font_size": { "unit": "px", "size": 28 } } },
            { "id": "p2-desc",  "elType": "widget", "widgetType": "text-editor", "settings": { "editor": "<p>Each chauffeur undergoes rigorous vetting, advanced driving certifications, and continuous training in international etiquette and discretion.</p>", "text_color": "rgba(229,229,229,0.6)" } }
          ]
        },
        {
          "id": "col-pillar-3",
          "elType": "column",
          "settings": { "_column_size": 33, "content_position": "top" },
          "elements": [
            { "id": "p3-title", "elType": "widget", "widgetType": "heading", "settings": { "title": "Discreet Security", "header_size": "h3", "title_color": "#E5E5E5", "typography_typography": "custom", "typography_font_family": "Cormorant Garamond", "typography_font_size": { "unit": "px", "size": 28 } } },
            { "id": "p3-desc",  "elType": "widget", "widgetType": "text-editor", "settings": { "editor": "<p>Absolute confidentiality of your itinerary, conversations, and personal data — guarded by ironclad operational protocols and trained professionals.</p>", "text_color": "rgba(229,229,229,0.6)" } }
          ]
        }
      ]
    },
    {
      "id": "sec-inquiry",
      "elType": "section",
      "settings": {
        "background_background": "classic",
        "background_color": "#0B0C10",
        "padding": { "unit": "px", "top": "96", "right": "24", "bottom": "112", "left": "24", "isLinked": false }
      },
      "elements": [
        {
          "id": "col-inquiry",
          "elType": "column",
          "settings": { "_column_size": 100, "content_position": "center" },
          "elements": [
            { "id": "inq-title", "elType": "widget", "widgetType": "heading", "settings": { "title": "Request a Bespoke Quotation.", "align": "center", "header_size": "h2", "title_color": "#E5E5E5", "typography_typography": "custom", "typography_font_family": "Cormorant Garamond", "typography_font_size": { "unit": "px", "size": 44 } } },
            { "id": "inq-desc",  "elType": "widget", "widgetType": "text-editor", "settings": { "editor": "<p style=\"max-width:560px;margin:20px auto 32px;text-align:center;font-weight:300;\">Share your itinerary, and a dedicated concierge will respond within one business hour with a tailored proposal — discretion guaranteed.</p>", "text_color": "rgba(229,229,229,0.6)" } },
            { "id": "inq-form",  "elType": "widget", "widgetType": "shortcode", "settings": { "shortcode": "[wpforms id=\"1\"]" } }
          ]
        }
      ]
    }
  ]
}
